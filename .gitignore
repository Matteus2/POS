# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# ── Caixa Padaria: nunca commitar APKs nem chaves de assinatura ──
# APKs vão pras GitHub Releases (binários), não pro repo (código).
*.apk
*.aab
*.apks

# Chaves de assinatura — NUNCA versionar. Compromete o app
# e Google Play rejeita updates assinados com chave nova.
key.properties
*.jks
*.keystore
android/app/upload-keystore.jks

# Banco SQLite local (se algum dia for exportado)
*.db
*.sqlite
*.sqlite3

